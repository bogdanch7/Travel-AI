# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# WhatsApp Provider Selection (meta | twilio | bridge)
WHATSAPP_PROVIDER=bridge

# WhatsApp Meta (optional if using Twilio)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_BOT_NAME=VolaBot
WHATSAPP_BRIDGE_URL=http://localhost:3001

# WhatsApp Twilio (optional if using Meta)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_BASE_URL=
TWILIO_VALIDATE_SIGNATURE=false

# OpenAI / Featherless.ai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.featherless.ai/v1
OPENAI_MODEL=meta-llama/Llama-3-70b-Instruct
OPENAI_VISION_MODEL=gpt-4o

# Redis (local or cloud)
REDIS_URL=redis://localhost:6379

# Postgres (local or cloud)
DATABASE_URL=postgresql://postgres@localhost:5432/vola_travel

# Vola.ro
VOLA_BASE_URL=https://www.vola.ro
VOLA_SEARCH_CACHE_TTL=300
